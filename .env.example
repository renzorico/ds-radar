# Required for the default evaluator/CV pipeline model.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional when overriding the model to an OpenAI family model.
OPENAI_API_KEY=your_openai_api_key_here

# Optional model override used by evaluate.py and generate_pdf.py when --model is not passed.
MODEL_OVERRIDE=claude-haiku-4-5-20251001

# Optional task-wide provider override; usually inferred from MODEL_OVERRIDE or task model.
DS_RADAR_LLM_PROVIDER=anthropic

# Optional per-task model pin for evaluations when MODEL_OVERRIDE is unset.
DS_RADAR_EVAL_MODEL=claude-haiku-4-5-20251001

# Optional per-task model pin for CV rewrites when MODEL_OVERRIDE is unset.
DS_RADAR_CV_MODEL=claude-haiku-4-5-20251001
